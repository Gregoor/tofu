{
  "name": "tofu-vscode",
  "displayName": "Tofu",
  "description": "Tofu editor embedded in VSCode",
  "version": "3.0.0",
  "publisher": "Gregor Weber",
  "engines": {
    "vscode": "^1.46.0"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "update-commands": "node out/update-commands",
    "test": "jest /out"
  },
  "dependencies": {
    "@babel/generator": "^7.13.16",
    "@babel/parser": "^7.13.16",
    "lodash.pick": "^4.4.0",
    "memoize-one": "^5.2.1",
    "prettier": "^2.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.13.16",
    "@babel/preset-env": "^7.13.15",
    "@babel/preset-typescript": "^7.13.0",
    "@swc/core": "^1.2.55",
    "@types/glob": "^7.1.3",
    "@types/jest": "^26.0.23",
    "@types/lodash.pick": "^4.4.6",
    "@types/node": "^14.14.41",
    "@types/prettier": "^2.2.3",
    "@types/vscode": "^1.55.0",
    "glob": "^7.1.6",
    "husky": "^6.0.0",
    "import-sort-style-module": "^6.0.0",
    "jest": "^26.6.3",
    "prettier-plugin-import-sort": "^0.0.6",
    "pretty-quick": "^3.1.0",
    "typescript": "^4.2.4",
    "vscode-test": "^1.5.2"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onView:tofuActionsView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "tofuActionsView",
          "name": "Actions"
        }
      ]
    },
    "commands": [
      {
        "command": "tofu:moveCursor:LEFT",
        "title": "tofu:moveCursor:LEFT"
      },
      {
        "command": "tofu:moveCursor:RIGHT",
        "title": "tofu:moveCursor:RIGHT"
      },
      {
        "command": "tofu:moveCursor:UP",
        "title": "tofu:moveCursor:UP"
      },
      {
        "command": "tofu:moveCursor:DOWN",
        "title": "tofu:moveCursor:DOWN"
      },
      {
        "command": "tofu:addLine",
        "title": "tofu:addLine"
      },
      {
        "command": "tofu:selectRange:UP",
        "title": "tofu:selectRange:UP"
      },
      {
        "command": "tofu:selectRange:DOWN",
        "title": "tofu:selectRange:DOWN"
      },
      {
        "command": "tofu:selectRange:LEFT",
        "title": "tofu:selectRange:LEFT"
      },
      {
        "command": "tofu:selectRange:RIGHT",
        "title": "tofu:selectRange:RIGHT"
      },
      {
        "command": "tofu:stretch",
        "title": "tofu:stretch"
      },
      {
        "command": "tofu:NumericLiteral:decimalize",
        "title": "tofu:NumericLiteral:decimalize"
      },
      {
        "command": "tofu:Identifier:assign",
        "title": "tofu:Identifier:assign"
      },
      {
        "command": "tofu:BinaryExpression:changeOperation:&",
        "title": "tofu:BinaryExpression:changeOperation:&"
      },
      {
        "command": "tofu:BinaryExpression:changeOperation:|",
        "title": "tofu:BinaryExpression:changeOperation:|"
      },
      {
        "command": "tofu:BinaryExpression:changeOperation:+",
        "title": "tofu:BinaryExpression:changeOperation:+"
      },
      {
        "command": "tofu:BinaryExpression:changeOperation:-",
        "title": "tofu:BinaryExpression:changeOperation:-"
      },
      {
        "command": "tofu:BinaryExpression:changeOperation:*",
        "title": "tofu:BinaryExpression:changeOperation:*"
      },
      {
        "command": "tofu:BinaryExpression:changeOperation:/",
        "title": "tofu:BinaryExpression:changeOperation:/"
      },
      {
        "command": "tofu:BinaryExpression:changeOperation:=",
        "title": "tofu:BinaryExpression:changeOperation:="
      },
      {
        "command": "tofu:BinaryExpression:changeOperation:<",
        "title": "tofu:BinaryExpression:changeOperation:<"
      },
      {
        "command": "tofu:BinaryExpression:changeOperation:>",
        "title": "tofu:BinaryExpression:changeOperation:>"
      },
      {
        "command": "tofu:LogicalExpression:changeOperation:&",
        "title": "tofu:LogicalExpression:changeOperation:&"
      },
      {
        "command": "tofu:LogicalExpression:changeOperation:|",
        "title": "tofu:LogicalExpression:changeOperation:|"
      },
      {
        "command": "tofu:LogicalExpression:changeOperation:+",
        "title": "tofu:LogicalExpression:changeOperation:+"
      },
      {
        "command": "tofu:LogicalExpression:changeOperation:-",
        "title": "tofu:LogicalExpression:changeOperation:-"
      },
      {
        "command": "tofu:LogicalExpression:changeOperation:*",
        "title": "tofu:LogicalExpression:changeOperation:*"
      },
      {
        "command": "tofu:LogicalExpression:changeOperation:/",
        "title": "tofu:LogicalExpression:changeOperation:/"
      },
      {
        "command": "tofu:LogicalExpression:changeOperation:=",
        "title": "tofu:LogicalExpression:changeOperation:="
      },
      {
        "command": "tofu:LogicalExpression:changeOperation:<",
        "title": "tofu:LogicalExpression:changeOperation:<"
      },
      {
        "command": "tofu:LogicalExpression:changeOperation:>",
        "title": "tofu:LogicalExpression:changeOperation:>"
      },
      {
        "command": "tofu:ArrayExpression:moveElement:LEFT",
        "title": "tofu:ArrayExpression:moveElement:LEFT"
      },
      {
        "command": "tofu:ArrayExpression:moveElement:RIGHT",
        "title": "tofu:ArrayExpression:moveElement:RIGHT"
      },
      {
        "command": "tofu:ObjectProperty:addObjectPropertyValue",
        "title": "tofu:ObjectProperty:addObjectPropertyValue"
      },
      {
        "command": "tofu:FunctionExpression:makeAsync",
        "title": "tofu:FunctionExpression:makeAsync"
      },
      {
        "command": "tofu:ArrowFunctionExpression:convert:FunctionExpression",
        "title": "tofu:ArrowFunctionExpression:convert:FunctionExpression"
      },
      {
        "command": "tofu:VariableDeclaration:changeDeclarationKind:const",
        "title": "tofu:VariableDeclaration:changeDeclarationKind:const"
      },
      {
        "command": "tofu:VariableDeclaration:changeDeclarationKind:let",
        "title": "tofu:VariableDeclaration:changeDeclarationKind:let"
      },
      {
        "command": "tofu:VariableDeclaration:changeDeclarationKind:var",
        "title": "tofu:VariableDeclaration:changeDeclarationKind:var"
      },
      {
        "command": "tofu:VariableDeclarator:assign",
        "title": "tofu:VariableDeclarator:assign"
      },
      {
        "command": "tofu:IfStatement:addElse",
        "title": "tofu:IfStatement:addElse"
      },
      {
        "command": "tofu:IfStatement:addElseIf",
        "title": "tofu:IfStatement:addElseIf"
      },
      {
        "command": "tofu:IfStatement:changeElseToElseIf",
        "title": "tofu:IfStatement:changeElseToElseIf"
      },
      {
        "command": "tofu:ForOfStatement:convert:ForStatement",
        "title": "tofu:ForOfStatement:convert:ForStatement"
      },
      {
        "command": "tofu:FunctionDeclaration:makeAsync",
        "title": "tofu:FunctionDeclaration:makeAsync"
      },
      {
        "command": "tofu:FunctionDeclaration:export",
        "title": "tofu:FunctionDeclaration:export"
      },
      {
        "command": "tofu:JSXText:makeExpression",
        "title": "tofu:JSXText:makeExpression"
      },
      {
        "command": "tofu:JSXAttribute:assign",
        "title": "tofu:JSXAttribute:assign"
      },
      {
        "command": "tofu:Expression:wrap:string",
        "title": "tofu:Expression:wrap:string"
      },
      {
        "command": "tofu:Expression:wrap:array",
        "title": "tofu:Expression:wrap:array"
      },
      {
        "command": "tofu:Expression:wrap:object",
        "title": "tofu:Expression:wrap:object"
      },
      {
        "command": "tofu:Expression:wrap:call",
        "title": "tofu:Expression:wrap:call"
      },
      {
        "command": "tofu:Expression:wrap:arrow",
        "title": "tofu:Expression:wrap:arrow"
      },
      {
        "command": "tofu:Expression:wrap:jsx",
        "title": "tofu:Expression:wrap:jsx"
      },
      {
        "command": "tofu:Expression:wrap:ternary",
        "title": "tofu:Expression:wrap:ternary"
      },
      {
        "command": "tofu:Expression:makeMember",
        "title": "tofu:Expression:makeMember"
      },
      {
        "command": "tofu:Expression:makeCall",
        "title": "tofu:Expression:makeCall"
      },
      {
        "command": "tofu:Expression:makeComputedMember",
        "title": "tofu:Expression:makeComputedMember"
      },
      {
        "command": "tofu:Expression:makeOperation:and",
        "title": "tofu:Expression:makeOperation:and"
      },
      {
        "command": "tofu:Expression:makeOperation:or",
        "title": "tofu:Expression:makeOperation:or"
      },
      {
        "command": "tofu:Expression:makeOperation:eq",
        "title": "tofu:Expression:makeOperation:eq"
      }
    ],
    "keybindings": [
      {
        "command": "tofu:moveCursor:LEFT",
        "key": "left",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:moveCursor:LEFT"
      },
      {
        "command": "tofu:moveCursor:RIGHT",
        "key": "right",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:moveCursor:RIGHT"
      },
      {
        "command": "tofu:moveCursor:UP",
        "key": "up",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:moveCursor:UP"
      },
      {
        "command": "tofu:moveCursor:DOWN",
        "key": "down",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:moveCursor:DOWN"
      },
      {
        "command": "tofu:addLine",
        "key": "Enter",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:addLine"
      },
      {
        "command": "tofu:selectRange:UP",
        "key": "Shift+up",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:selectRange:UP"
      },
      {
        "command": "tofu:selectRange:DOWN",
        "key": "Shift+down",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:selectRange:DOWN"
      },
      {
        "command": "tofu:selectRange:LEFT",
        "key": "Shift+left",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:selectRange:LEFT"
      },
      {
        "command": "tofu:selectRange:RIGHT",
        "key": "Shift+right",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:selectRange:RIGHT"
      },
      {
        "command": "tofu:stretch",
        "key": "Alt+up",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:stretch"
      },
      {
        "command": "tofu:ArrayExpression:moveElement:LEFT",
        "key": "Alt+ArrowLeft",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:ArrayExpression:moveElement:LEFT"
      },
      {
        "command": "tofu:ArrayExpression:moveElement:RIGHT",
        "key": "Alt+ArrowRight",
        "when": "editorTextFocus && !findWidgetVisible && !suggestWidgetVisible && !renameInputVisible && !inReferenceSearchEditor && !quickFixWidgetVisible && tofu:hasAST && tofu:ArrayExpression:moveElement:RIGHT"
      }
    ]
  },
  "importSort": {
    ".js, .jsx, .es6, .es, .mjs, .ts, .tsx": {
      "parser": "babylon",
      "style": "module"
    }
  }
}
